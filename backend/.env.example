NODE_ENV=development
PORT=4000

MONGODB_URI=mongodb://127.0.0.1:27017/pharmacy_saas

# Production root domain used for tenant subdomains:
#   abcpharmacy.mypharmacyapp.com -> slug=abcpharmacy
ROOT_DOMAIN=mypharmacyapp.com

# Local development tenant portal URL (what SuperAdmin sees after approval)
DEV_TENANT_PROTOCOL=http
DEV_TENANT_HOST=localhost:5173

JWT_ACCESS_SECRET=change-me-access
JWT_ACCESS_EXPIRES_IN=1h

# Allowed frontend origins (comma separated) for CORS in development
CORS_ORIGINS=http://localhost:5173
